# OpenAI API key (required) — used for extraction, embeddings, chat
OPENAI_API_KEY=sk-...

# JWT secret for auth tokens (change in production)
JWT_SECRET=change-me-in-production

# Database — local Postgres with pgvector
DATABASE_URL=postgresql://soip_admin:soip_secure_password@localhost:5432/soip_db

# Crawl depth per source:
# - html paginated sources => max pages
# - infinite-scroll (Crawl4AI full_page, e.g. Unstop) => max scroll steps
CRAWL_MAX_PAGES=3

# Extraction: 1 = validate on first page of content only; 3 = first 3 segments; 0 = all segments
EXTRACTION_MAX_SEGMENTS=3

# Cross-encoder reranker (local)
RERANK_ENABLED=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=30
RERANK_BATCH_SIZE=16

# Scrape concurrency (parallel sources)
SCRAPE_CONCURRENCY=1

# Dev mode: run scraper only via CLI, disable scheduler
SCRAPE_CLI_ONLY=false
